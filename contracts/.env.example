# CloudGreen OS — Smart Contract Environment
# Copy to .env and populate before deploying.

# Deployer account private key (WITHOUT 0x prefix)
# Generate: npx hardhat account:generate
# Fund with MATIC from https://faucet.polygon.technology/
DEPLOYER_PRIVATE_KEY=

# Polygon Amoy RPC endpoint
# Default public RPC works, but rate-limited. Use Alchemy/Infura for production.
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# PolygonScan API key for contract verification
# Register at: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=

# Optional: Gas reporting
REPORT_GAS=false
